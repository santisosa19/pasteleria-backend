generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MeasurementKind {
  MASS
  VOLUME
  UNIT
}

enum StockMovementType {
  PURCHASE_IN
  SALE_OUT
  PRODUCTION_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

enum StockMovementSourceType {
  PURCHASE
  SALE
  ORDER
  MANUAL_ADJUSTMENT
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  DELIVERED
  CANCELLED
}

enum OrderChannel {
  INTERNAL
  ECOMMERCE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique @db.VarChar(80)
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(120)
  description String?          @db.VarChar(255)
  roles       RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  username       String          @unique @db.VarChar(80)
  email          String          @unique @db.VarChar(255)
  passwordHash   String          @map("password_hash") @db.VarChar(255)
  firstName      String          @map("first_name") @db.VarChar(120)
  lastName       String          @map("last_name") @db.VarChar(120)
  isActive       Boolean         @default(true) @map("is_active")
  roleId         String          @map("role_id") @db.Uuid
  role           Role            @relation(fields: [roleId], references: [id])
  refreshTokens  RefreshToken[]
  purchases      Purchase[]
  sales          Sale[]
  stockMovements StockMovement[]
  auditLogs      AuditLog[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Supplier {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @db.VarChar(180)
  taxId     String?    @map("tax_id") @db.VarChar(80)
  email     String?    @db.VarChar(255)
  phone     String?    @db.VarChar(80)
  address   String?    @db.VarChar(255)
  notes     String?
  purchases Purchase[]
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("suppliers")
}

model MeasurementUnit {
  id                   String             @id @default(uuid()) @db.Uuid
  code                 String             @unique @db.VarChar(20)
  name                 String             @db.VarChar(80)
  kind                 MeasurementKind
  conversionRateToBase Decimal            @map("conversion_rate_to_base") @db.Decimal(18, 6)
  isBase               Boolean            @default(false) @map("is_base")
  rawMaterials         RawMaterial[]
  recipeIngredients    RecipeIngredient[]
  recipeYields         Recipe[]
  purchaseItems        PurchaseItem[]
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@map("measurement_units")
}

model RawMaterial {
  id               String             @id @default(uuid()) @db.Uuid
  name             String             @unique @db.VarChar(160)
  description      String?
  baseUnitId       String             @map("base_unit_id") @db.Uuid
  baseUnit         MeasurementUnit    @relation(fields: [baseUnitId], references: [id])
  currentStock     Decimal            @default(0) @map("current_stock") @db.Decimal(18, 4)
  minimumStock     Decimal            @default(0) @map("minimum_stock") @db.Decimal(18, 4)
  averageCost      Decimal            @default(0) @map("average_cost") @db.Decimal(18, 4)
  lastPurchaseCost Decimal?           @map("last_purchase_cost") @db.Decimal(18, 4)
  isActive         Boolean            @default(true) @map("is_active")
  recipeItems      RecipeIngredient[]
  purchaseItems    PurchaseItem[]
  stockMovements   StockMovement[]
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@map("raw_materials")
}

model Recipe {
  id            String             @id @default(uuid()) @db.Uuid
  name          String             @unique @db.VarChar(160)
  description   String?
  yieldQuantity Decimal            @map("yield_quantity") @db.Decimal(18, 4)
  yieldUnitId   String             @map("yield_unit_id") @db.Uuid
  yieldUnit     MeasurementUnit    @relation(fields: [yieldUnitId], references: [id])
  instructions  String?
  isActive      Boolean            @default(true) @map("is_active")
  ingredients   RecipeIngredient[]
  products      Product[]
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@map("recipes")
}

model RecipeIngredient {
  id            String          @id @default(uuid()) @db.Uuid
  recipeId      String          @map("recipe_id") @db.Uuid
  recipe        Recipe          @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rawMaterialId String          @map("raw_material_id") @db.Uuid
  rawMaterial   RawMaterial     @relation(fields: [rawMaterialId], references: [id])
  quantity      Decimal         @db.Decimal(18, 4)
  unitId        String          @map("unit_id") @db.Uuid
  unit          MeasurementUnit @relation(fields: [unitId], references: [id])
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@unique([recipeId, rawMaterialId])
  @@map("recipe_ingredients")
}

model Product {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @unique @db.VarChar(160)
  description String?
  sku         String?     @unique @db.VarChar(80)
  recipeId    String?     @map("recipe_id") @db.Uuid
  recipe      Recipe?     @relation(fields: [recipeId], references: [id])
  salePrice   Decimal     @map("sale_price") @db.Decimal(18, 2)
  isPublished Boolean     @default(false) @map("is_published")
  isActive    Boolean     @default(true) @map("is_active")
  saleItems   SaleItem[]
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("products")
}

model Purchase {
  id          String         @id @default(uuid()) @db.Uuid
  supplierId  String?        @map("supplier_id") @db.Uuid
  supplier    Supplier?      @relation(fields: [supplierId], references: [id])
  invoiceNo   String?        @map("invoice_no") @db.VarChar(100)
  purchasedAt DateTime       @map("purchased_at")
  totalAmount Decimal        @map("total_amount") @db.Decimal(18, 2)
  notes       String?
  createdById String         @map("created_by_id") @db.Uuid
  createdBy   User           @relation(fields: [createdById], references: [id])
  items       PurchaseItem[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("purchases")
}

model PurchaseItem {
  id            String          @id @default(uuid()) @db.Uuid
  purchaseId    String          @map("purchase_id") @db.Uuid
  purchase      Purchase        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  rawMaterialId String          @map("raw_material_id") @db.Uuid
  rawMaterial   RawMaterial     @relation(fields: [rawMaterialId], references: [id])
  quantity      Decimal         @db.Decimal(18, 4)
  unitId        String          @map("unit_id") @db.Uuid
  unit          MeasurementUnit @relation(fields: [unitId], references: [id])
  unitCost      Decimal         @map("unit_cost") @db.Decimal(18, 4)
  subtotal      Decimal         @db.Decimal(18, 2)
  createdAt     DateTime        @default(now()) @map("created_at")

  @@map("purchase_items")
}

model StockMovement {
  id               String                  @id @default(uuid()) @db.Uuid
  rawMaterialId    String                  @map("raw_material_id") @db.Uuid
  rawMaterial      RawMaterial             @relation(fields: [rawMaterialId], references: [id])
  type             StockMovementType
  quantityBase     Decimal                 @map("quantity_base") @db.Decimal(18, 4)
  unitCostSnapshot Decimal?                @map("unit_cost_snapshot") @db.Decimal(18, 4)
  sourceType       StockMovementSourceType @map("source_type")
  sourceId         String?                 @map("source_id") @db.Uuid
  note             String?
  createdById      String                  @map("created_by_id") @db.Uuid
  createdBy        User                    @relation(fields: [createdById], references: [id])
  createdAt        DateTime                @default(now()) @map("created_at")

  @@index([rawMaterialId, createdAt])
  @@map("stock_movements")
}

model Sale {
  id          String     @id @default(uuid()) @db.Uuid
  status      SaleStatus @default(CONFIRMED)
  soldAt      DateTime   @map("sold_at")
  subtotal    Decimal    @db.Decimal(18, 2)
  discount    Decimal    @default(0) @db.Decimal(18, 2)
  totalAmount Decimal    @map("total_amount") @db.Decimal(18, 2)
  grossProfit Decimal    @default(0) @map("gross_profit") @db.Decimal(18, 2)
  createdById String     @map("created_by_id") @db.Uuid
  createdBy   User       @relation(fields: [createdById], references: [id])
  orderId     String?    @unique @map("order_id") @db.Uuid
  order       Order?     @relation(fields: [orderId], references: [id])
  items       SaleItem[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("sales")
}

model SaleItem {
  id               String  @id @default(uuid()) @db.Uuid
  saleId           String  @map("sale_id") @db.Uuid
  sale             Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId        String  @map("product_id") @db.Uuid
  product          Product @relation(fields: [productId], references: [id])
  quantity         Decimal @db.Decimal(18, 4)
  unitPrice        Decimal @map("unit_price") @db.Decimal(18, 2)
  unitCostEstimate Decimal @default(0) @map("unit_cost_estimate") @db.Decimal(18, 4)
  subtotal         Decimal @db.Decimal(18, 2)
  profitEstimate   Decimal @default(0) @map("profit_estimate") @db.Decimal(18, 2)

  @@map("sale_items")
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String   @map("first_name") @db.VarChar(120)
  lastName  String?  @map("last_name") @db.VarChar(120)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(80)
  address   String?  @db.VarChar(255)
  orders    Order[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("customers")
}

model Order {
  id            String       @id @default(uuid()) @db.Uuid
  customerId    String?      @map("customer_id") @db.Uuid
  customer      Customer?    @relation(fields: [customerId], references: [id])
  channel       OrderChannel @default(INTERNAL)
  status        OrderStatus  @default(PENDING)
  requestedDate DateTime?    @map("requested_date")
  subtotal      Decimal      @db.Decimal(18, 2)
  discount      Decimal      @default(0) @db.Decimal(18, 2)
  totalAmount   Decimal      @map("total_amount") @db.Decimal(18, 2)
  notes         String?
  items         OrderItem[]
  payments      Payment[]
  sale          Sale?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @map("order_id") @db.Uuid
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id])
  quantity  Decimal @db.Decimal(18, 4)
  unitPrice Decimal @map("unit_price") @db.Decimal(18, 2)
  subtotal  Decimal @db.Decimal(18, 2)

  @@map("order_items")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  orderId           String?       @map("order_id") @db.Uuid
  order             Order?        @relation(fields: [orderId], references: [id])
  provider          String        @db.VarChar(80)
  providerPaymentId String?       @map("provider_payment_id") @db.VarChar(160)
  status            PaymentStatus @default(PENDING)
  amount            Decimal       @db.Decimal(18, 2)
  paidAt            DateTime?     @map("paid_at")
  rawPayload        Json?         @map("raw_payload")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([provider, providerPaymentId])
  @@map("payments")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  actorUser   User?    @relation(fields: [actorUserId], references: [id])
  action      String   @db.VarChar(120)
  entityName  String   @map("entity_name") @db.VarChar(120)
  entityId    String?  @map("entity_id") @db.Uuid
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityName, entityId])
  @@map("audit_logs")
}
